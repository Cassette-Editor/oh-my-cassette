# This root example is materialized as ~/.hermes/plugins/cassette/.env by the
# Hermes installation channel. The Codex/Claude MCP plugin does NOT load it;
# run scripts/setup_local_mcp.py for protected host-neutral configuration.

# Cassette account. Keep real values out of git.
CASSETTE_AUTH_EMAIL=you@example.com
CASSETTE_AUTH_PASSWORD=replace-with-your-private-cassette-password

# Transport: API is the default. Browser requires explicit Playwright setup.
CASSETTE_TRANSPORT=api
CASSETTE_URL=https://sg.trycassette.online/agent
# CASSETTE_API_URL=https://remotion-canvas-server-5tdb2hkb4q-as.a.run.app

# Hermes adapter storage and gateway media roots.
CASSETTE_ASSET_ROOT=$HOME/.hermes/cassette
CASSETTE_ALLOWED_SOURCE_ROOTS=$HOME/.hermes/qqbot:$HOME/.hermes/telegram:$HOME/.hermes/cache:$HOME/.hermes/tmp

# Browser transport and gateway normalization.
CASSETTE_HEADLESS=true
CASSETTE_FORCE_H264=true
CASSETTE_FORCE_H264_PLATFORMS=weixin,qqbot,qq,telegram,web
CASSETTE_BROWSER_TIMEOUT_SEC=1800
# CASSETTE_UPLOAD_TIMEOUT_SEC=

# API transport. Product model IDs:
# deepseek/deepseek-v4-flash, deepseek/deepseek-v4-pro, openai/gpt-5.4-mini
# CASSETTE_API_MODEL_ID=deepseek/deepseek-v4-flash
CASSETTE_API_RUN_START_TIMEOUT_SEC=120
CASSETTE_API_MEDIA_READY_TIMEOUT_SEC=300
# CASSETTE_EXPORT_TIMEOUT_SEC=
# CASSETTE_API_DEFAULT_ASK_USER_REPLY=
CASSETTE_API_AUTO_EXPORT=false
CASSETTE_API_EXPORT_THUMBNAIL=true

# Native MCP overrides (normally leave unset and use platform-standard paths).
# CASSETTE_CONFIG_HOME=/absolute/private/config/directory
# CASSETTE_DATA_HOME=/absolute/private/data/directory
# CASSETTE_PROJECT_ROOTS=/absolute/project:/another/trusted/project
CASSETTE_MCP_MONITOR_BUDGET_SEC=1500

# Optional smart BGM.
CASSETTE_SMART_BGM_ENABLED=true
CASSETTE_EXACT_BGM_ENABLED=true
CASSETTE_EXACT_BGM_SOURCES=netease,qq,kuwo,joox
JAMENDO_CLIENT_ID=replace-with-your-client-id
JAMENDO_CLIENT_SECRET=replace-with-your-client-secret
# CASSETTE_EXACT_BGM_JOOX_TOKEN=replace-only-if-the-public-token-stops-working

# Web demo only. The retained FastAPI service reads process environment and
# remains separate from the local MCP child process and Cassette backend.
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
OMC_WEB_HOST=0.0.0.0
OMC_WEB_PORT=8080
